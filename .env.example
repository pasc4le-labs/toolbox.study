# Relay configuration
RELAY_PORT=8080
RELAY_ROOM_TTL_SECONDS=600
RELAY_SWEEP_INTERVAL_SECONDS=30

# Frontend
NEXT_PUBLIC_RELAY_URL=ws://localhost:8080/ws

# Gemini Gem URLs (optional) — shown as a "Gemini Gem" button on the
# Import page for the matching format. Leave unset to hide the button.
NEXT_PUBLIC_GEMINI_UQF_GEM=
NEXT_PUBLIC_GEMINI_JSON_GEM=
