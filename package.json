{
  "name": "studying-tools",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc -noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "cd e2e && pnpm exec playwright test",
    "test:e2e:all": "cd e2e && pnpm exec playwright test --project=chromium --project=mobile-chrome --project=mobile-safari",
    "test:e2e:headed": "cd e2e && pnpm exec playwright test --headed",
    "postinstall": "node copy-wasm.mjs",
    "db:generate": "drizzle-kit generate",
    "db:export": "tsx scripts/export-migrations.ts",
    "db:migrate": "pnpm db:generate && pnpm db:export"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.79",
    "@ai-sdk/google": "^3.0.79",
    "@ai-sdk/openai-compatible": "^2.0.48",
    "@iconify/react": "^6.0.2",
    "@remixicon/react": "^4.9.0",
    "@unovis/react": "^1.6.5",
    "@unovis/ts": "^1.6.5",
    "ai": "^6.0.191",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "shadcn": "^4.7.0",
    "simple-peer-light": "^9.10.0",
    "sonner": "^2.0.7",
    "sql.js": "^1.14.1",
    "tailwind-merge": "^3.6.0",
    "ts-fsrs": "^5.4.1",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/sql.js": "^1.4.11",
    "@vitest/coverage-v8": "^4.1.8",
    "babel-plugin-react-compiler": "1.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "^4",
    "tsx": "^4.22.1",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
